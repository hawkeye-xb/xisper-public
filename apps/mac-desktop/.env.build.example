# Xisper macOS Native Build Environment
# Copy this file to .env.build and fill in the values.
# .env.build is gitignored — NEVER commit the real file.

# ── Apple Notarization ────────────────────────────────────────────────
# Apple ID: your Apple Developer account email
APPLE_ID=your-email@example.com

# App-Specific Password: generate at https://appleid.apple.com
#   → Sign-In and Security → App-Specific Passwords → Generate
#   → Name it "Xisper Notarize" → copy the xxxx-xxxx-xxxx-xxxx value
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Team ID: your Apple Developer team
APPLE_TEAM_ID=2WJUWVUJBN

# ── Code Signing ──────────────────────────────────────────────────────
# Certificate identity for Developer ID signing (find via: security find-identity -v -p codesigning)
CODE_SIGN_IDENTITY=Developer ID Application: Zhaowen Li (2WJUWVUJBN)

# ── Sparkle Auto-Update ──────────────────────────────────────────────
# EdDSA private key (base64). Export from Keychain: generate_keys -x keyfile
# Only needed if Keychain doesn't have it (new machine setup via setup script).
SPARKLE_PRIVATE_KEY=

# ── Cloudflare R2 (release upload) ───────────────────────────────────
# Option A: Use wrangler CLI (recommended, no keys needed — just run `wrangler login`)
# Option B: Use AWS CLI with R2 API keys (fill these in)
R2_BUCKET_NAME=xisper-releases
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT=https://5e82e5129e1ff4c1076933dd481a6e7f.r2.cloudflarestorage.com

# ── Release Promote ──────────────────────────────────────────────────
# Secret for triggering promote API (same value set in Cloudflare Workers)
MAC_UPDATE_PROMOTE_SECRET=
