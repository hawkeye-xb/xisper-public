{
  "name": "@xisper/landing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "pnpm --filter @xisper/icons build:icons",
    "build": "vite-ssg build",
    "preview": "vite preview",
    "type-check": "vue-tsc --build",
    "deploy": "pnpm run build && wrangler pages deploy dist --project-name xisper-landing"
  },
  "dependencies": {
    "@xisper/icons": "workspace:*",
    "lucide-vue-next": "^0.511.0",
    "vue": "^3.5.22",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.11",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitejs/plugin-vue-jsx": "^5.1.1",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.9.0",
    "vite": "^7.1.11",
    "vite-ssg": "^28.3.0",
    "vue-tsc": "^3.1.1"
  }
}
