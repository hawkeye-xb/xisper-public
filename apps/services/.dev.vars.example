# Local Development Environment Variables
# Environment variables for local development
# Copy this file to .dev.vars and fill in real values

# ============================================
# Logto authentication configuration
# ============================================
# Logto endpoint (from the Logto console)
LOGTO_ENDPOINT=https://your-tenant.logto.app

# Logto application ID (usually beta/xisper-dev for local development)
LOGTO_APP_ID=your-logto-app-id

# Logto App Secret (usually not needed in SPA mode; not needed for backend token verification)
# Only required for Machine-to-Machine or direct backend calls
LOGTO_APP_SECRET=

# Browser origins allowed to send credentialed API requests.
# Local development automatically allows localhost and 127.0.0.1.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# AI API keys
# ============================================
# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key

# DeepSeek API Key (optional)
DEEPSEEK_API_KEY=your-deepseek-api-key

# ============================================
# Creem payment platform (https://creem.io)
# ============================================
# Creem API Key (from Dashboard → Settings → API Keys)
# Test mode: creem_test_xxx, Live mode: creem_xxx
CREEM_API_KEY=creem_test_your-api-key
CREEM_PRODUCT_PRO_MONTHLY=your-creem-monthly-product-id
CREEM_PRODUCT_PRO_YEARLY=your-creem-yearly-product-id

# Creem webhook secret (from Dashboard → Settings → Webhooks)
PAYMENT_WEBHOOK_SECRET=your-webhook-secret

# Independent admin authentication. Use long random values.
ADMIN_JWT_SECRET=replace-with-at-least-32-random-bytes
# Required only for POST /api/v1/admin-auth/setup. Remove after bootstrap.
ADMIN_SETUP_SECRET=replace-with-a-one-time-random-secret

# ============================================
# Polar payment platform (https://polar.sh)
# ============================================
# Payment provider selection. Creem is the default implementation; Paddle requires API, price, and webhook configuration.
# Polar keeps the adapter interface, but its webhook stays disabled until signature verification is complete.
PAYMENT_PROVIDER=creem

# Polar API token (from Dashboard → Settings → API)
POLAR_ACCESS_TOKEN=your-polar-access-token
POLAR_PRODUCT_PRO_MONTHLY=your-polar-monthly-product-id

# Polar webhook secret (from Dashboard → Webhooks)
POLAR_WEBHOOK_SECRET=your-polar-webhook-secret

# Polar server environment: 'sandbox' or 'production'
POLAR_SERVER=sandbox

# ============================================
# Paddle payment platform (https://paddle.com)
# ============================================
# Paddle API Key (from Developer Tools → Authentication)
PADDLE_ACCESS_TOKEN=your-paddle-api-key
PADDLE_PRICE_PRO_MONTHLY=your-paddle-monthly-price-id

# Paddle Vendor ID (obtained after KYC)
PADDLE_VENDOR_ID=your-vendor-id

# Paddle webhook secret (from Developer Tools → Webhooks)
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret

# Paddle server environment: 'sandbox' or 'production'
PADDLE_SERVER=sandbox

# ============================================
# Alibaba Cloud ASR configuration (used by the current ASR proxy)
# ============================================
# Alibaba Cloud DashScope API Key (from https://dashscope.console.aliyun.com)
ALIBABA_API_KEY=your-alibaba-dashscope-api-key

# ============================================
# Doubao ASR configuration (deprecated)
# ============================================
# Doubao speech recognition App ID (from the Volcano Engine console)
DOUBAO_APP_ID=your-doubao-app-id

# Doubao speech recognition Access Token
DOUBAO_ACCESS_TOKEN=your-doubao-access-token

# Doubao Resource ID (optional, default value)
DOUBAO_RESOURCE_ID=volc.bigasr.sauc.duration

# Doubao cluster configuration (optional)
DOUBAO_CLUSTER=

# ============================================
# App Update / R2 configuration
# ============================================
# R2 endpoint (Cloudflare Account ID)
# Format: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# R2 access keys (from Cloudflare Dashboard → R2 → API Tokens)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# R2 bucket name (used to store app update files)
R2_BUCKET_NAME=xisper-releases

# R2 public access URL (r2.dev public address or custom domain)
R2_PUBLIC_URL=https://releases.example.com

# Browser origins allowed to call the API, comma separated.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ============================================
# Notes
# ============================================
# 1. The .dev.vars file is gitignored and will not be committed
# 2. Set production secrets with `wrangler secret put`
# 3. Never commit real secrets to the repository
# 4. In SPA mode, the frontend uses LOGTO_APP_ID; the backend only needs LOGTO_ENDPOINT
