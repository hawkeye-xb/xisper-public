# Production Environment Variables
# This file is for production environment configuration
# Copy this file to .env.production and fill in real values
# Use ./scripts/cf-sync-secrets.sh to sync to Cloudflare

# ============================================
# Logto Authentication Configuration
# ============================================
LOGTO_ENDPOINT=https://your-tenant.logto.app
LOGTO_APP_ID=your-production-app-id
LOGTO_APP_SECRET=your-production-app-secret

# ============================================
# AI API Keys
# ============================================
OPENAI_API_KEY=sk-your-production-openai-api-key
DEEPSEEK_API_KEY=your-production-deepseek-api-key

# ============================================
# Alibaba ASR Configuration (required for speech recognition)
# ============================================
ALIBABA_API_KEY=your-alibaba-dashscope-api-key

# ============================================
# Doubao ASR Configuration (legacy, not used by current ASR proxy)
# ============================================
DOUBAO_APP_ID=your-doubao-app-id
DOUBAO_ACCESS_TOKEN=your-doubao-access-token
DOUBAO_RESOURCE_ID=volc.bigasr.sauc.duration
DOUBAO_CLUSTER=

# ============================================
# Optional: Payment Integration
# ============================================
PAYMENT_WEBHOOK_SECRET=your-production-webhook-secret
CREEM_PRODUCT_PRO_MONTHLY=your-creem-monthly-product-id
CREEM_PRODUCT_PRO_YEARLY=your-creem-yearly-product-id
# Optional adapters:
POLAR_PRODUCT_PRO_MONTHLY=your-polar-monthly-product-id
PADDLE_PRICE_PRO_MONTHLY=your-paddle-monthly-price-id
ADMIN_JWT_SECRET=replace-with-at-least-32-random-bytes
ADMIN_SETUP_SECRET=replace-with-a-one-time-random-secret

# ============================================
# App Update / R2 Configuration
# ============================================
R2_ENDPOINT=https://your-production-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_production_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_production_r2_secret_access_key
R2_BUCKET_NAME=xisper-releases
R2_PUBLIC_URL=https://releases.example.com
ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# ============================================
# Notes
# ============================================
# 1. .env.production file is ignored by .gitignore
# 2. Use ./scripts/cf-sync-secrets.sh production to sync to Cloudflare
# 3. Never commit real secrets to the repository
