{
  "name": "@xisper/services",
  "version": "0.1.0",
  "description": "Xisper backend services based on Cloudflare Workers",
  "main": "src/index.ts",
  "scripts": {
    "dev": "NO_PROXY='*' HTTP_PROXY='' HTTPS_PROXY='' wrangler dev",
    "dev:remote": "NO_PROXY='*' HTTP_PROXY='' HTTPS_PROXY='' wrangler dev --remote",
    "dev:remote:beta": "NO_PROXY='*' HTTP_PROXY='' HTTPS_PROXY='' wrangler dev --remote --env beta",
    "deploy": "wrangler deploy",
    "deploy:beta": "bash ../../scripts/deploy.sh services beta",
    "deploy:prod": "bash ../../scripts/deploy.sh services production",
    "tail": "wrangler tail",
    "tail:beta": "wrangler tail --env beta",
    "tail:prod": "wrangler tail --env production",
    "db:init": "wrangler d1 execute ai-services-db-dev --file=./database/schema.sql",
    "db:init:prod": "wrangler d1 execute ai-services-db-prod --env production --remote --file=./database/schema.sql",
    "db:query": "wrangler d1 execute ai-services-db-dev",
    "check": "wrangler deployments list",
    "check-types": "tsc --noEmit"
  },
  "keywords": [
    "cloudflare-workers",
    "ai",
    "serverless",
    "hono",
    "logto",
    "edge-computing",
    "xisper"
  ],
  "author": "Xisper Team",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.2.0",
    "@polar-sh/hono": "^0.5.5",
    "@scalar/hono-api-reference": "^0.9.39",
    "@xisper/prompts": "workspace:*",
    "hono": "^4.4.0",
    "jose": "^6.1.3",
    "zod": "^4.3.6"
  }
}
